{
  "name": "@kingimperio/lens",
  "version": "0.1.0",
  "description": "Real-time token usage and cost monitor for AI agent workflows. Runs as a local proxy. Zero config required.",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "lens": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "esbuild src/cli.js --bundle --platform=node --format=esm --outfile=dist/cli.js --external:better-sqlite3 --external:ink --external:react --external:express --external:http-proxy-middleware --loader:.js=jsx --loader:.jsx=jsx",
    "dev": "node --experimental-vm-modules src/cli.js",
    "start": "node dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KingImperio/lens.git"
  },
  "keywords": [
    "ai",
    "llm",
    "proxy",
    "monitor",
    "cost",
    "tokens",
    "openai",
    "anthropic",
    "nvidia"
  ],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/KingImperio/lens/issues"
  },
  "homepage": "https://github.com/KingImperio/lens#readme",
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "express": "^5.2.1",
    "figures": "^6.1.0",
    "http-proxy-middleware": "^4.1.1",
    "ink": "^7.0.6",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "esbuild": "^0.28.1"
  }
}